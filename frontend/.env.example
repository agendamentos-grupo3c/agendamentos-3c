# ==========================================================================
# Frontend (Vercel) — copie para .env.local e preencha.
# Somente variáveis NEXT_PUBLIC_* chegam ao navegador e só podem conter
# o que é público por natureza. NENHUM segredo aqui.
# ==========================================================================

# URL base da API (backend na Render)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3333

# Google Client ID (público por natureza). O Client Secret fica SÓ no backend.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

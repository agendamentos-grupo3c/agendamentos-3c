# ==========================================================================
# Backend (Render) — copie para .env e preencha com valores reais.
# NUNCA commite o .env. Todos os segredos vivem APENAS no backend.
# ==========================================================================

# Servidor
NODE_ENV=development
PORT=3333

# Origem do front (Vercel) — usada no CORS (sem curinga "*")
FRONTEND_ORIGIN=http://localhost:3000

# Sessão (cookie httpOnly assinado / JWT de sessão)
SESSION_SECRET=

# --- Google OAuth / OIDC ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# URL de callback do backend registrada no Google Cloud Console (Authorized
# redirect URI). Ex.: http://localhost:3333/auth/google/callback
GOOGLE_REDIRECT_URI=

# --- Controle de acesso ---
ALLOWED_DOMAIN=grupo-3c.com
# OPCIONAL: se vazia, qualquer e-mail @grupo-3c.com acessa. Se preenchida
# (lista separada por vírgula), restringe o acesso só a esses e-mails.
ALLOWLIST_EMAILS=

# --- Google Calendar ---
# Refresh token da conta agendamentos@grupo-3c.com (escopo calendar.events), obtido
# uma vez via consentimento OAuth offline. Só no backend.
GOOGLE_CALENDAR_REFRESH_TOKEN=
# IDs das agendas compartilhadas = os e-mails dos colaboradores.
CALENDAR_ALANA_ID=alana.gaspar@grupo-3c.com
CALENDAR_GUILHERME_ID=

# --- Implantação ---
# Agendas dos implantadores (e-mails). agendamentos@ precisa de acesso de edição.
CALENDAR_GABRIELLE_ID=
CALENDAR_BRYAN_ID=
CALENDAR_WAGNER_ID=
# Webhook do n8n que dispara WhatsApp + e-mail ao confirmar a implantação.
N8N_IMPLANTACAO_WEBHOOK=
# Webhook do n8n que reenvia WhatsApp + e-mail quando um kickoff é reagendado.
N8N_REAGENDAMENTO_WEBHOOK=

# --- Neon (PostgreSQL) ---
# Endpoint POOLED (com "-pooler" no host) — usado pela aplicação.
DATABASE_URL=
# Conexão DIRETA (sem "-pooler") — usada apenas pelas migrations.
DATABASE_URL_UNPOOLED=

# Slack, WhatsApp e ClickUp são tratados pelo fluxo n8n da 3C (delegado).
# As variáveis dessas integrações foram removidas daqui.
